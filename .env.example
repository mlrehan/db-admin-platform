# =============================================================================
# docker-compose environment. Copy to `.env` and fill in the secrets.
#
# Generate secrets:
#   JWT secret      : python -c "import secrets; print(secrets.token_urlsafe(48))"
#   Master AES key  : python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
# =============================================================================

# --- Control-plane database ---
CONTROL_DB_USER=dbadmin
CONTROL_DB_PASSWORD=change-me-strong-password
CONTROL_DB_NAME=db_admin_platform

# --- Security (REQUIRED in production) ---
SECURITY_JWT_SECRET=                      # >= 32 chars
SECURITY_MASTER_ENCRYPTION_KEY=           # base64 of exactly 32 random bytes (AES-256)

# --- First admin user (created on first start if both are set) ---
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=                 # >= 12 chars

# --- CORS / networking ---
API_CORS_ORIGINS=http://localhost:8080
FRONTEND_PORT=8080
BACKEND_PORT=8000
LOG_LEVEL=INFO
