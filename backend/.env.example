# =============================================================================
# DB Admin Platform — backend environment template.
# Copy to `.env` and fill in. NEVER commit a real `.env`.
# Generate secrets:
#   JWT secret      : python -c "import secrets; print(secrets.token_urlsafe(48))"
#   Master AES key  : python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
# =============================================================================

# --- Application ---
APP_NAME=DB Admin Platform
APP_VERSION=0.1.0
APP_ENVIRONMENT=local          # local | development | staging | production
APP_DEBUG=true

# --- HTTP server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_FORWARDED_ALLOW_IPS=127.0.0.1

# --- API ---
API_PREFIX=/api/v1
API_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
API_REQUEST_TIMEOUT_SECONDS=30

# --- Control-plane database (platform's own PostgreSQL) ---
CONTROL_DB_HOST=localhost
CONTROL_DB_PORT=5432
CONTROL_DB_USER=dbadmin
CONTROL_DB_PASSWORD=change-me-in-production
CONTROL_DB_NAME=db_admin_platform
CONTROL_DB_POOL_SIZE=10
CONTROL_DB_MAX_OVERFLOW=20
CONTROL_DB_POOL_TIMEOUT=30
CONTROL_DB_POOL_RECYCLE=1800
CONTROL_DB_ECHO_SQL=false

# --- Security ---
# Required in staging/production (the app refuses to boot without them there).
SECURITY_JWT_SECRET=                         # >= 32 chars
SECURITY_JWT_ALGORITHM=HS256
SECURITY_ACCESS_TOKEN_TTL_SECONDS=900
SECURITY_REFRESH_TOKEN_TTL_SECONDS=1209600
SECURITY_JWT_ISSUER=db-admin-platform
SECURITY_MASTER_ENCRYPTION_KEY=              # base64 of exactly 32 random bytes (AES-256)

# --- Connection Orchestrator (live target-DB sessions) ---
CONN_MAX_SESSIONS_PER_USER=10
CONN_SESSION_IDLE_TTL_SECONDS=1800
CONN_REAPER_INTERVAL_SECONDS=60
CONN_CONNECT_TIMEOUT_SECONDS=10
CONN_SESSION_POOL_MIN_SIZE=1
CONN_SESSION_POOL_MAX_SIZE=5

# --- Query Engine ---
QUERY_DEFAULT_MAX_ROWS=1000
QUERY_MAX_ROWS_LIMIT=100000
QUERY_STREAM_BATCH_SIZE=500
QUERY_STATEMENT_TIMEOUT_SECONDS=60

# --- Logging ---
LOG_LEVEL=INFO                                # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=console                            # json | console
